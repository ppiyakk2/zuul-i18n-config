# Local testing credentials (sourced by tools/local/lib/common.sh).
# Copy to .env.local (gitignored) and fill in secrets.

# Weblate API (both upstream and propose jobs).
export WEBLATE_URL="https://weblate.example.com/api/"
export WEBLATE_TOKEN=""

# GitHub API (propose job only).
export GITHUB_TOKEN=""
export FORK_OWNER="<your-org>"

# Where target project checkouts live. Each project is expected at
# ${TARGETS_ROOT}/<project-short-name> pointing to the fork.
export TARGETS_ROOT="${HOME}/work/i18n/test_env"

# Appended to the GitHub PR branch name so local runs never touch
# production PR branches (weblate/translations/<target_branch><suffix>).
# Requires the LOCAL_TEST_BRANCH_SUFFIX hook in common_translation_update.sh.
export LOCAL_TEST_BRANCH_SUFFIX="-localtest"

# Python interpreter used to create ~/.venv. Defaults to a pyenv 3.10 install
# (matches the OpenStack runtime most translation jobs target). Override if
# your pyenv layout differs.
export LOCAL_PYTHON="${HOME}/.pyenv/versions/3.10.12/bin/python3"
